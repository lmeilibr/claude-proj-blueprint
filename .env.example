# Memory Layer — pgvector (only if using shared backend)
# PGVECTOR_PASSWORD=your-secure-password

# Embedding — cloud providers (only if NOT using local model)
# OPENAI_API_KEY=sk-...
# VOYAGE_API_KEY=pa-...

# [SPEC] Add your project env vars below
# DATABASE_URL=postgresql://user:pass@localhost:5432/mydb
# SECRET_KEY=your-secret-key
# API_KEY=your-api-key
